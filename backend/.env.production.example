# Backend Production Environment (Render Web Service)
# Copy to backend/.env on the server and replace all placeholder values.

# Database Configuration
# Preferred on Render: set DATABASE_URL from Render PostgreSQL (Internal URL)
# DATABASE_URL=postgres://user:pass@host:5432/dbname

DB_HOST=<RENDER_POSTGRES_HOST>
DB_PORT=5432
DB_USER=<DB_USERNAME>
DB_PASSWORD=<DB_PASSWORD>
DB_NAME=id_card_system
# Optional explicit SSL flag for managed Postgres providers
DB_SSL=true

# Server Configuration
PORT=5000
NODE_ENV=production

# Security
JWT_SECRET=<LONG_RANDOM_SECRET_AT_LEAST_32_CHARS>

# File Upload
MAX_FILE_SIZE=5242880

# Frontend URL used in scheduling emails (student link target)
FRONTEND_URL=https://<YOUR_RENDER_FRONTEND>.onrender.com

# Comma-separated allowed browser origins for CORS
# Example: https://id-card-unit-frontend.onrender.com,https://idcard.yourdomain.com
CORS_ORIGINS=https://<YOUR_RENDER_FRONTEND>.onrender.com

# Optional: allow all Vercel preview domains (*.vercel.app)
# Set to true only if you need Vercel preview deployments to access the API.
CORS_ALLOW_VERCEL_PREVIEWS=false

# Capture service endpoint (if used)
CAPTURE_APP_URL=http://<CAPTURE_SERVICE_PRIVATE_DNS_OR_IP>:5001
CAPTURE_APP_OUTPUT_DIR=/home/ubuntu/id-card-unit/backend/uploads/output
VERIFY_API_KEY=<VERIFY_API_KEY>

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SECURITY=TLS
SMTP_USER=<SMTP_USER>
SMTP_PASS=<SMTP_PASS>
SMTP_FROM="ID Card Unit" <noreply@ui.edu.ng>
