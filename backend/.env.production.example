# Backend Production Environment (Vercel)
# Set these in: Vercel Project Settings > Environment Variables

# Database Configuration
# Use a managed PostgreSQL provider (e.g. Neon, Supabase, Railway)
# Preferred: set DATABASE_URL (connection string from your provider)
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Individual DB fields (used if DATABASE_URL is not set)
DB_HOST=<YOUR_POSTGRES_HOST>
DB_PORT=5432
DB_USER=<DB_USERNAME>
DB_PASSWORD=<DB_PASSWORD>
DB_NAME=id_card_system
DB_SSL=true

# Server Configuration
NODE_ENV=production

# Security
JWT_SECRET=<LONG_RANDOM_SECRET_AT_LEAST_32_CHARS>

# File Upload
MAX_FILE_SIZE=5242880

# Frontend URL used in scheduling emails (student link target)
FRONTEND_URL=https://id-card-unit.vercel.app

# CORS — not needed when frontend and backend are on the same Vercel domain.
# Only set if you have a custom domain or separate deployment.
# CORS_ORIGINS=https://yourdomain.com

# Capture service endpoint (if used)
CAPTURE_APP_URL=http://<CAPTURE_SERVICE_HOST>:5001
CAPTURE_APP_OUTPUT_DIR=/tmp/uploads/output
VERIFY_API_KEY=<VERIFY_API_KEY>

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SECURITY=TLS
SMTP_USER=<SMTP_USER>
SMTP_PASS=<SMTP_PASS>
SMTP_FROM="ID Card Unit" <noreply@ui.edu.ng>
