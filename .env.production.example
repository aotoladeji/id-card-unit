# Frontend Production Environment (Amplify)
# Set this in AWS Amplify Console > App settings > Environment variables.

# Recommended for this project: keep /api and use Amplify rewrite to backend.
# This keeps existing fetch('/api/...') and axios calls working consistently.
VITE_API_BASE_URL=/api

# Alternative (direct backend calls):
# VITE_API_BASE_URL=https://<BACKEND_DOMAIN>/api
